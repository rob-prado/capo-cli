{
  "name": "capo-cli",
  "version": "1.0.0",
  "description": "Agent-First React Native Whitelabel CLI",
  "type": "module",
  "main": "src/init.js",
  "bin": {
    "capo": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/init.js",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "inquirer": "^9.2.16"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "shfmt": "^0.0.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.sh": [
      "shfmt -w -i 4 -ci"
    ]
  }
}
